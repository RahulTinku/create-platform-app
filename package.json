    "start": "node dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "create-app",
    "scaffolding",
    "platform-engineering",
    "react",
    "nextjs",
    "enterprise",
    "developer-experience"
